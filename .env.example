# --- Required for the live pipeline (server-side only, never NEXT_PUBLIC) ---
ANTHROPIC_API_KEY=sk-ant-...
FIRECRAWL_API_KEY=fc-...

# --- Optional: caching (Upstash Redis via Vercel Marketplace). App runs without it. ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Optional: email capture (Loops). App runs without it. ---
LOOPS_API_KEY=

# --- Phase 3: Postgres via Supabase (community platform). App runs without these; the DB
# --- client is a silent null until DATABASE_URL exists (lib/db). ---
# Transaction-pooler connection string (Supabase -> Connect -> Transaction pooler), SERVER-ONLY:
DATABASE_URL=
# Project URL + anon key are public BY DESIGN (Supabase model: safety comes from Row-Level
# Security, not key secrecy) — hence the NEXT_PUBLIC_ prefix, as an explicit exception:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key bypasses RLS — SERVER-ONLY, used by ingestion/admin (G2+):
SUPABASE_SERVICE_ROLE_KEY=

# --- Dev/design only: preview the WHOLE UI (reading -> streaming cards -> email) with no keys. ---
# Only takes effect when ANTHROPIC_API_KEY is unset, so it can never shadow a real key —
# once your key is set, the real Firecrawl + Claude pipeline always runs.
# MOCK_PIPELINE=1
