# --- Required for the live pipeline (server-side only, never NEXT_PUBLIC) ---
ANTHROPIC_API_KEY=sk-ant-...
FIRECRAWL_API_KEY=fc-...

# --- Optional: caching (Upstash Redis via Vercel Marketplace). App runs without it. ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Optional: email capture (Loops). App runs without it. ---
LOOPS_API_KEY=

# --- Dev/design only: preview the WHOLE UI (reading -> streaming cards -> email) with no keys. ---
# Only takes effect when ANTHROPIC_API_KEY is unset, so it can never shadow a real key —
# once your key is set, the real Firecrawl + Claude pipeline always runs.
# MOCK_PIPELINE=1
